{
  "name": "pulumi-github-action",
  "version": "2.0.0",
  "main": "dist/index.js",
  "repository": "git@github.com:pulumi/actions",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rimraf coverage build tmp dist",
    "prebuild": "yarn run clean",
    "build": "ncc build src/main.ts -e typescript -o dist --source-map",
    "postbuild": "node scripts/replace-ts.js",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --coverage src/**/*",
    "test:watch": "jest --watch",
    "postinstall": "husky install .github/husky"
  },
  "lint-staged": {
    "src/**/*.{yaml,yml}": "prettier --write",
    "src/**/*.{js,ts}": "eslint --cache --fix",
    ".eslintrc": "prettier --write",
    "*.md": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@types/dedent": "^0.7.2",
    "@types/faker": "^6.6.11",
    "@types/jest": "~30.0.0",
    "@types/node": "~25.9.3",
    "@vercel/ncc": "^0.44.0",
    "eslint": "~10.5.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-import-x": "~4.16.2",
    "eslint-plugin-jest": "~29.15.2",
    "faker": "^6.6.6",
    "globals": "~17.6.0",
    "husky": "^9.1.7",
    "jest": "~30.4.2",
    "jest-playback": "^4.1.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "rimraf": "~6.1.3",
    "ts-jest": "~29.4.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.59.1"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "@pulumi/pulumi": "^3.246.0",
    "actions-parsers": "^1.0.2",
    "dedent": "^1.7.2",
    "envalid": "^8.2.0",
    "got": "^15.0.5",
    "runtypes": "^7.0.4",
    "semver": "^7.6.1",
    "ts-invariant": "^0.10.3",
    "tslib": "^2.8.1"
  }
}

{
  "name": "pulumi-github-action",
  "version": "2.0.0",
  "main": "dist/index.js",
  "repository": "git@github.com:pulumi/actions",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rimraf coverage build tmp dist",
    "prebuild": "yarn run clean",
    "build": "ncc build src/main.ts -e typescript -o dist --source-map",
    "postbuild": "node scripts/replace-ts.js",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --coverage src/**/*",
    "test:watch": "jest --watch",
    "postinstall": "husky install .github/husky"
  },
  "lint-staged": {
    "src/**/*.{yaml,yml}": "prettier --write",
    "src/**/*.{js,ts}": "eslint --cache --fix",
    ".eslintrc": "prettier --write",
    "*.md": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@types/dedent": "^0.7.0",
    "@types/faker": "^6.6.9",
    "@types/jest": "~30.0.0",
    "@types/node": "~24.0.0",
    "@vercel/ncc": "^0.36.1",
    "eslint": "~10.2.1",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-import-x": "~4.16.2",
    "eslint-plugin-jest": "~29.15.2",
    "faker": "^6.6.6",
    "globals": "~17.5.0",
    "husky": "^8.0.3",
    "jest": "~30.3.0",
    "jest-playback": "^3.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^2.8.8",
    "rimraf": "~5.0.1",
    "ts-jest": "~29.4.9",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.59.1"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^5.1.1",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.1",
    "@pulumi/pulumi": "^3.206.0",
    "actions-parsers": "^1.0.2",
    "dedent": "^0.7.0",
    "envalid": "^7.3.1",
    "got": "^11.8.6",
    "runtypes": "^6.7.0",
    "semver": "^7.6.1",
    "ts-invariant": "^0.10.3",
    "tslib": "^2.8.1"
  }
}
